FROM ubuntu:26.04

RUN export DEBIAN_FRONTEND=noninteractive && apt-get update && \
    apt-get install -y \
    casacore-dev \
    cmake \
    g++ \
    libblas-dev \
    libboost-date-time-dev \
    libboost-filesystem-dev \
    libboost-thread-dev \
    libcfitsio-dev \
    libfftw3-dev \
    libgsl-dev \
    libhdf5-dev \
    liblapack-dev \
    libxml2-dev \
    pkg-config \
    wget && \
  rm -rf /var/lib/apt/lists/*

ADD . /src
WORKDIR /src

RUN \
  mkdir /build && \
  cd /build && \
  cmake ../src && \
  make -j`nproc`
